---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title='Resume'>
    <article class="resume-container">
        <header class="resume-header">
            <h1>Resume</h1>
            <p class="resume-subtitle">Professional experience and background</p>
        </header>

        <section class="resume-section">
            <h2>Work History</h2>
            <ul class="work-list">
                <li class="work-card">
                    <div class="work-header">
                        <h3>Red Ants Caribbean Ventures</h3>
                        <span class="work-role">Part Time Developer</span>
                    </div>
                    <p>
                        My role was admittedly small, being mostly responsible for making
                        small bugfixes to the now defunct sales platform.
                    </p>
                </li>
                <li class="work-card">
                    <div class="work-header">
                        <h3>UNIPET</h3>
                        <span class="work-role">Fuel Dispatcher</span>
                    </div>
                    <p>
                        This is my full time job, and the first real job I got after graduating
                        university. Simply put, I was stationed at the fuel supplier's facility and responsible
                        for creating documents, and ensuring that the daily master schedule was adhered to and that
                        customers received their fuel in a timely manner.
                    </p>
                </li>
            </ul>
        </section>
    </article>
</BaseLayout>

<style>
    .resume-container {
        max-width: 800px;
        margin: 0 auto;
        padding: var(--spacing-xl) 0;
    }

    .resume-header {
        margin-bottom: var(--spacing-2xl);
        padding-bottom: var(--spacing-lg);
        border-bottom: 1px solid var(--border-color);
    }

    .resume-header h1 {
        margin-bottom: var(--spacing-sm);
    }

    .resume-subtitle {
        font-size: 1.125rem;
        color: var(--text-secondary);
    }

    .resume-section h2 {
        margin-bottom: var(--spacing-lg);
    }

    .work-list {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .work-card {
        background-color: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-card);
        padding: var(--spacing-lg);
        transition: box-shadow 0.3s ease, border-color 0.3s ease;
    }

    .work-card:hover {
        box-shadow: var(--shadow-card-hover);
        border-color: var(--color-electric-blue);
    }

    .work-header {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-md);
    }

    @media (min-width: 640px) {
        .work-header {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .work-header h3 {
        margin: 0;
        color: var(--text-primary);
    }

    .work-role {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-electric-blue);
        padding: var(--spacing-xs) var(--spacing-sm);
        background-color: rgba(0, 194, 255, 0.1);
        border-radius: var(--radius-pill);
    }

    .work-card p {
        margin: 0;
        line-height: 1.6;
    }
</style>
