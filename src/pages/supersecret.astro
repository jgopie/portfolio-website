---
import { ValentinesDay } from "../components/valentinesday/valentinesday";
import { buildCanonicalUrl } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

export const prerender = false;

const hasValentineCookie = Astro.cookies.get("valentinesday_yes")?.value === "1";
---

<BaseLayout
  title="Super Secret Page"
  description="A private interactive page on Jordan Gopie's site."
  canonicalUrl={buildCanonicalUrl('/supersecret')}
>
    <ValentinesDay client:load initialCelebrated={hasValentineCookie} />
</BaseLayout>
