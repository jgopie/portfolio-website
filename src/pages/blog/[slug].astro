---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import { buildCanonicalUrl, siteConfig } from '../../data/site';

export async function getStaticPaths() {
    const blogEntries = await getCollection('blog');
    return blogEntries
      .filter((entry) => !entry.data.isDraft)
      .map((entry) => ({
        params: {slug: entry.id},
        props: {entry}
    }));
}

const {entry} = Astro.props;
const {Content} = await render(entry);
const ogImage = entry.data.image
  ? `${siteConfig.siteUrl}/${entry.data.image}`
  : undefined;
---
<BlogLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  canonicalUrl={buildCanonicalUrl(`/blog/${entry.id}`)}
  publishedDate={entry.data.publishedDate}
  author={entry.data.author}
  tags={entry.data.tags}
  ogImage={ogImage}
>
    <Content/>
</BlogLayout>
