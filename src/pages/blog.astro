---
import {getCollection} from 'astro:content'
const blogPosts = await getCollection("blog")
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog-card/BlogCard.astro'
// Can't just let me sort by date, can you Javascript?
const sortedPosts = blogPosts.sort((a, b) => {
    return a.data.publishedDate.getTime() - b.data.publishedDate.getTime();
})
---
<BaseLayout title='Blog'>
    <div class="blog-container">
        <header class="blog-header">
            <h1>Blog</h1>
            <p class="blog-subtitle">For all my ramblings, musings, and thoughts about stuff</p>
        </header>

        <ul class="blog-list">
        {
            sortedPosts.map((post) => (
                <li>
                    <BlogCard title={post.data.title} image={post.data.image} slug={post.slug}/>
                </li>
            )).reverse()
        }
        </ul>
    </div>
</BaseLayout>

<style>
    .blog-container {
        max-width: 900px;
        margin: 0 auto;
        padding: var(--spacing-xl) 0;
    }

    .blog-header {
        margin-bottom: var(--spacing-2xl);
        padding-bottom: var(--spacing-lg);
        border-bottom: 1px solid var(--border-color);
    }

    .blog-header h1 {
        margin-bottom: var(--spacing-sm);
    }

    .blog-subtitle {
        font-size: 1.125rem;
        color: var(--text-secondary);
    }

    .blog-list {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .blog-list li {
        list-style: none;
    }
</style>
