---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog-card/BlogCard.astro';
import { buildCanonicalUrl } from '../data/site';

const blogPosts = await getCollection('blog');
const publishedPosts = blogPosts
  .filter((post) => !post.data.isDraft)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
---
<BaseLayout
  title="Notes"
  description="Jordan Gopie's field notes on full-stack work, automation, client constraints, deployment pain, and practical engineering lessons."
  canonicalUrl={buildCanonicalUrl('/blog')}
>
    <div class="notes-container">
        <header class="notes-header">
            <p class="blog-eyebrow">Notes index</p>
            <h1>Things I learned while trying to make the software behave.</h1>
            <p class="notes-subtitle">
                Some posts are polished. Some are old enough to show the awkward phase. That is the point:
                a record of shipped work, stuck work, and the judgment that accumulates between them.
            </p>
        </header>

        <ul class="notes-list">
        {
            publishedPosts.map((post, index) => (
                <li>
                    <BlogCard
                      title={post.data.title}
                      excerpt={post.data.excerpt}
                      image={post.data.image}
                      publishedDate={post.data.publishedDate}
                      slug={post.id}
                      tags={post.data.tags}
                      index={index + 1}
                    />
                </li>
            ))
        }
        </ul>
    </div>
</BaseLayout>

<style>
    .notes-container {
        display: grid;
        gap: clamp(1.4rem, 3.5vw, 2.75rem);
        padding-block: clamp(2rem, 5vw, 4.5rem);
    }

    .notes-header {
        display: grid;
        gap: clamp(0.8rem, 2vw, var(--spacing-md));
        max-width: 68rem;
        padding-bottom: clamp(1.1rem, 3vw, 2rem);
        border-bottom: var(--rule);
    }

    .notes-header h1 {
        max-width: 13ch;
        font-size: clamp(3.4rem, 7.4vw, 6.25rem);
        line-height: 0.94;
    }

    .notes-subtitle {
        color: var(--text-primary);
        max-width: 56rem;
        font-size: clamp(1.02rem, 1.55vw, 1.28rem);
        line-height: 1.55;
    }

    .notes-list {
        display: grid;
        gap: 0.75rem;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .notes-list li {
        list-style: none;
    }

    @media (max-width: 640px) {
        .notes-header h1 {
            max-width: 9ch;
            font-size: clamp(3.25rem, 15vw, 4.9rem);
        }
    }
</style>
