---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/blog-card/BlogCard.astro';
import { buildCanonicalUrl } from '../data/site';

const blogPosts = await getCollection('blog');
const publishedPosts = blogPosts
  .filter((post) => !post.data.isDraft)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
---
<BaseLayout
  title="Blog"
  description="Writing on full-stack development, automation, product engineering, and lessons from client work."
  canonicalUrl={buildCanonicalUrl('/blog')}
>
    <div class="blog-container">
        <header class="blog-header">
            <p class="blog-eyebrow">Writing</p>
            <h1>Notes on shipping software that holds up in production.</h1>
            <p class="blog-subtitle">
                Essays, project reflections, and engineering notes from building full-stack products,
                automation systems, and client work.
            </p>
        </header>

        <ul class="blog-list">
        {
            publishedPosts.map((post) => (
                <li>
                    <BlogCard
                      title={post.data.title}
                      excerpt={post.data.excerpt}
                      image={post.data.image}
                      publishedDate={post.data.publishedDate}
                      slug={post.id}
                      tags={post.data.tags}
                    />
                </li>
            ))
        }
        </ul>
    </div>
</BaseLayout>

<style>
    .blog-container {
        max-width: 900px;
        margin: 0 auto;
        padding: var(--spacing-xl) 0;
    }

    .blog-header {
        display: grid;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-2xl);
        padding-bottom: var(--spacing-lg);
        border-bottom: 1px solid var(--border-color);
    }

    .blog-eyebrow {
        color: var(--color-electric-blue);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .blog-header h1 {
        margin-bottom: var(--spacing-sm);
        line-height: 1.2;
        padding-bottom: 0.06em;
    }

    .blog-subtitle {
        font-size: 1.125rem;
        color: var(--text-secondary);
        max-width: 42rem;
    }

    .blog-list {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-lg);
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .blog-list li {
        list-style: none;
    }
</style>
