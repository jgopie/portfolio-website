---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildCanonicalUrl, siteConfig } from "../data/site";

const proofPoints = [
  {
    label: "End-to-end delivery",
    value: "Frontend, backend, automation, and deployment owned together.",
  },
  {
    label: "Workflow automation",
    value: "Systems built to remove repetitive work and survive messy edge cases.",
  },
  {
    label: "Production mindset",
    value: "Testing, observability, and reliability matter as much as shipping fast.",
  },
];

const caseStudies = [
  {
    title: "MLS Broker Portal",
    problem:
      "Agents needed a fast way to browse MLS inventory, claim listings safely, and create CRM deals without duplicate work.",
    role: "Full-stack developer across backend and frontend",
    stack:
      "React, TypeScript, Python, Flask, Firebase Auth, Firestore, Cloud Run, Cloud Tasks, Google Cloud Storage",
    outcome:
      "Delivered atomic claim-and-create flows, scalable listing detail views, and async processing that reduced operational conflicts.",
    linkLabel: "Request walkthrough",
    linkHref: `mailto:${siteConfig.contactEmail}?subject=MLS%20Broker%20Portal%20walkthrough`,
  },
  {
    title: "Permit & Property Verification Pipeline",
    problem:
      "The business needed roof-related permit verification across multiple jurisdictions without relying on fragile manual research.",
    role: "Lead engineer building the pipeline solo",
    stack:
      "Python, TypeScript, FastAPI, Playwright-based browser automation, PostgreSQL, Docker",
    outcome:
      "Shipped scheduled verification runs, expanded jurisdiction support, and added live/integration coverage to reduce production regressions.",
    linkLabel: "Discuss implementation",
    linkHref: `mailto:${siteConfig.contactEmail}?subject=Permit%20Verification%20Pipeline%20walkthrough`,
  },
  {
    title: "WhatsApp AI Intake Automation",
    problem:
      "A legal intake workflow needed structured triage, human handoff, and auditable summaries without forcing leads through a traditional form.",
    role: "Technical owner from product shape to delivery",
    stack:
      "Next.js, TypeScript, PostgreSQL, Prisma, WhatsApp Cloud API, OpenAI API, OAuth 2.0",
    outcome:
      "Delivered concurrent chat handling, recommendation logic with reasons, escalation paths, and case-management syncing for qualified leads.",
    linkLabel: "Talk through the system",
    linkHref: `mailto:${siteConfig.contactEmail}?subject=WhatsApp%20AI%20Intake%20walkthrough`,
  },
];

const contactLinks = [
  { label: "Email", href: `mailto:${siteConfig.contactEmail}` },
  { label: "GitHub", href: siteConfig.githubUrl },
  { label: "LinkedIn", href: siteConfig.linkedinUrl },
];
---

<BaseLayout
  title="Portfolio"
  description="Jordan Gopie is a full-stack developer focused on product engineering, workflow automation, and reliable web systems."
  canonicalUrl={buildCanonicalUrl('/')}
>
  <section class="hero-section">
    <div class="hero-copy">
      <p class="hero-tagline">Full-stack developer</p>
      <h1>Shipping reliable software for teams that need less friction and more throughput.</h1>
      <p class="hero-description">
        I build web apps, backend services, and automation systems that replace repetitive
        manual work with software that teams can trust in production.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn-primary">View Projects</a>
        <a href="#contact" class="btn-secondary">Contact Me</a>
      </div>
      <p class="hero-supporting">
        Recent work spans broker tooling, browser automation, AI-assisted intake workflows,
        and internal systems with tight operational constraints.
      </p>
    </div>

    <div class="hero-identity" aria-hidden="true">
      <div class="hero-logo">
        <span class="hero-logo-letter hero-logo-j">J</span>
        <span class="hero-logo-letter hero-logo-g">G</span>
      </div>
      <div class="hero-status">
        <span>Product engineering</span>
        <span>Automation systems</span>
        <span>Client work</span>
      </div>
    </div>
  </section>

  <section class="about-section" aria-labelledby="about-title">
    <div class="section-heading">
      <p class="section-kicker">About</p>
      <h2 id="about-title">A product-minded engineer who likes untangling operational mess.</h2>
    </div>

    <div class="about-grid">
      <div class="about-copy">
        <p class="about-lede">
          Most of my recent work has been about taking a process that is slow, brittle, or
          hard to scale and turning it into something software can handle consistently.
        </p>
        <p>
          That usually means full-stack delivery across interface, API, automation, data
          handling, and deployment. I am most useful where the work touches both product
          decisions and implementation details, especially when reliability matters more than
          novelty.
        </p>
      </div>

      <div class="proof-grid">
        {
          proofPoints.map((point) => (
            <article class="proof-card">
              <h3>{point.label}</h3>
              <p>{point.value}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="projects-section" id="projects" aria-labelledby="projects-title">
    <div class="section-heading">
      <p class="section-kicker">Selected Work</p>
      <h2 id="projects-title">Three projects that show how I work.</h2>
      <p class="section-summary">
        Client-sensitive details stay private, but these summaries reflect the kind of
        systems I design and ship.
      </p>
    </div>

    <div class="projects-grid">
      {
        caseStudies.map((study) => (
          <article class="card project-card">
            <div class="project-header">
              <h3>{study.title}</h3>
              <a href={study.linkHref} class="project-link">
                {study.linkLabel}
              </a>
            </div>
            <div class="project-section">
              <span>Problem</span>
              <p>{study.problem}</p>
            </div>
            <div class="project-section">
              <span>Role</span>
              <p>{study.role}</p>
            </div>
            <div class="project-section">
              <span>Stack</span>
              <p>{study.stack}</p>
            </div>
            <div class="project-section">
              <span>Outcome</span>
              <p>{study.outcome}</p>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="writing-section" aria-labelledby="writing-title">
    <div class="writing-card">
      <div>
        <p class="section-kicker">Writing</p>
        <h2 id="writing-title">The blog is still here, just not driving the homepage.</h2>
        <p>
          I use it for engineering notes, postmortems, and reflections on real project work.
        </p>
      </div>
      <a href="/blog" class="btn-secondary">Read the Blog</a>
    </div>
  </section>

  <section class="contact-section" id="contact" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="section-kicker">Contact</p>
      <h2 id="contact-title">Need someone who can own the product and the implementation?</h2>
      <p class="section-summary">
        Email is the fastest way to reach me. GitHub and LinkedIn are here if you want a
        quick sanity check first.
      </p>
    </div>

    <div class="contact-grid">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            class="contact-card"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
          >
            <span>{link.label}</span>
            <span class="contact-arrow" aria-hidden="true">-&gt;</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section,
  .about-section,
  .projects-section,
  .writing-section,
  .contact-section {
    padding: var(--spacing-2xl) 0;
  }

  .about-section,
  .projects-section,
  .contact-section {
    border-top: 1px solid var(--border-color);
  }

  .hero-section {
    display: grid;
    gap: var(--spacing-2xl);
    align-items: center;
  }

  .hero-copy {
    display: grid;
    gap: var(--spacing-md);
  }

  .hero-copy h1 {
    max-width: 12ch;
    margin: 0;
  }

  .hero-tagline,
  .section-kicker {
    color: var(--color-electric-blue);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-description,
  .hero-supporting,
  .section-summary,
  .about-copy p,
  .writing-card p {
    max-width: 42rem;
    line-height: 1.7;
  }

  .hero-description {
    font-size: 1.125rem;
    color: var(--text-primary);
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin-top: var(--spacing-sm);
  }

  .hero-identity {
    display: grid;
    gap: var(--spacing-md);
    justify-items: start;
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid var(--border-color);
    border-radius: 28px;
    background:
      radial-gradient(circle at top right, rgba(0, 194, 255, 0.12), transparent 34%),
      radial-gradient(circle at bottom left, rgba(138, 46, 255, 0.12), transparent 34%),
      var(--bg-surface);
  }

  .hero-logo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.12em;
    font-family: var(--font-logo);
    font-size: clamp(5rem, 14vw, 8rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-logo-letter {
    display: inline-block;
  }

  .hero-logo-j {
    color: var(--color-electric-blue);
    text-shadow: 0 0 24px rgba(0, 194, 255, 0.35);
  }

  .hero-logo-g {
    color: var(--color-vibrant-purple);
    text-shadow: 0 0 24px rgba(138, 46, 255, 0.35);
  }

  .hero-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-status span,
  .project-section span {
    display: inline-flex;
    width: fit-content;
    padding: 0.4rem 0.7rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border-color);
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .section-heading {
    display: grid;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
  }

  .section-heading h2 {
    max-width: 18ch;
    margin: 0;
  }

  .about-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .about-copy {
    display: grid;
    gap: var(--spacing-md);
    max-width: 44rem;
  }

  .about-lede {
    color: var(--text-primary);
    font-size: 1.125rem;
  }

  .proof-grid,
  .projects-grid,
  .contact-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .proof-card {
    padding: var(--spacing-lg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-card);
    background: var(--bg-surface);
  }

  .proof-card h3,
  .project-card h3 {
    margin-bottom: 0.6rem;
  }

  .proof-card p,
  .project-card p {
    line-height: 1.7;
  }

  .project-card {
    display: grid;
    gap: var(--spacing-md);
  }

  .project-header {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    align-items: center;
    justify-content: space-between;
  }

  .project-link {
    color: var(--text-primary);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  .project-section {
    display: grid;
    gap: 0.55rem;
  }

  .writing-card {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    align-items: center;
    justify-content: space-between;
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    background: var(--bg-surface);
  }

  .contact-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    min-height: 72px;
    padding: var(--spacing-lg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-card);
    background: var(--bg-surface);
    color: var(--text-primary);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .contact-card:hover {
    border-color: var(--color-electric-blue);
  }

  .contact-card:focus-visible {
    border-color: var(--color-electric-blue);
  }

  .contact-arrow {
    color: var(--color-electric-blue);
  }

  @media (min-width: 820px) {
    .hero-section {
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.9fr);
    }

    .about-grid {
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
      align-items: start;
    }

    .proof-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .projects-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .contact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-logo {
      transition: transform 0.3s ease;
    }

    .hero-logo:hover {
      transform: scale(1.03);
    }
  }
</style>
