---
import { getCollection } from 'astro:content';
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildCanonicalUrl, siteConfig } from "../data/site";

const blogPosts = await getCollection('blog');
const publishedPosts = blogPosts
  .filter((post) => !post.data.isDraft)
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());

const featuredNote = publishedPosts[0];
const featuredDate = featuredNote
  ? new Intl.DateTimeFormat('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    }).format(featuredNote.data.publishedDate)
  : '';

const workLedger = [
  {
    title: "MLS Broker Portal",
    marker: "claim flow",
    role: "Full-stack build across React, Python, Firebase, Cloud Run, and async tasking.",
    note:
      "Designed listing detail surfaces and atomic claim-to-CRM behavior for work where duplicate ownership would have caused real operational pain.",
  },
  {
    title: "Permit & Property Verification Pipeline",
    marker: "automation",
    role: "Solo pipeline owner using Python, TypeScript, FastAPI, Playwright, PostgreSQL, and Docker.",
    note:
      "Turned brittle jurisdiction research into scheduled verification runs with integration coverage and fewer production surprises.",
  },
  {
    title: "WhatsApp AI Intake Automation",
    marker: "handoff",
    role: "Technical owner across Next.js, PostgreSQL, Prisma, WhatsApp Cloud API, OpenAI, and OAuth.",
    note:
      "Built structured triage, auditable summaries, human escalation, and case-management syncing for a conversational intake path.",
  },
];

const contactLinks = [
  { label: "Email", href: `mailto:${siteConfig.contactEmail}` },
  { label: "GitHub", href: siteConfig.githubUrl },
  { label: "LinkedIn", href: siteConfig.linkedinUrl },
];
---

<BaseLayout
  title="Field Notes"
  description="Jordan Gopie writes and builds from the messy middle of full-stack projects, automation, client constraints, and practical software work."
  canonicalUrl={buildCanonicalUrl('/')}
>
  <section class="desk-hero" aria-labelledby="home-title">
    <div class="desk-copy">
      <p class="hero-tagline">Late-night field notes</p>
      <h1 id="home-title">Jordan Gopie</h1>
      <p class="hero-statement">
        I build software in the part of the job where product ideas meet dates, client pressure,
        deployment constraints, and code that has to keep working after the demo.
      </p>
      <div class="hero-routes" aria-label="Primary routes">
        <a href="/blog" class="btn-primary">Read the notes</a>
        <a href="#work-ledger" class="btn-secondary">Scan the ledger</a>
      </div>
    </div>

    <aside class="featured-note" aria-label="Featured note">
      {featuredNote && (
        <a href={`/blog/${featuredNote.id}`} class="hero-slip">
          <span class="slip-label">Latest field slip</span>
          <time class="slip-date" datetime={featuredNote.data.publishedDate.toISOString()}>
            {featuredDate}
          </time>
          <strong>{featuredNote.data.title}</strong>
          <span class="slip-copy">{featuredNote.data.excerpt}</span>
          <span class="slip-margin">Filed after the tidy plan met the actual build.</span>
        </a>
      )}
    </aside>
  </section>

  <section class="now-section" aria-labelledby="now-title">
    <div class="section-heading">
      <p class="section-kicker">Current margin note</p>
      <h2 id="now-title">The useful work usually starts after the clean diagram stops being true.</h2>
    </div>
    <div class="note-columns">
      <p>
        This site is less a pitch than a record: what broke, what shipped, what I learned,
        and where software helped a real workflow become less fragile.
      </p>
      <p>
        The writing is intentionally uneven in age. Older notes stay visible because they show the
        route, not just the current posture.
      </p>
    </div>
  </section>

  <section class="work-section" id="work-ledger" aria-labelledby="work-title">
    <div class="section-heading">
      <p class="section-kicker">Ledger</p>
      <h2 id="work-title">A few shipped things, compressed into their pressure points.</h2>
    </div>

    <div class="ledger-list">
      {
        workLedger.map((entry, index) => (
          <article class="ledger-entry">
            <span class="ledger-number">{String(index + 1).padStart(2, '0')}</span>
            <div>
              <p class="ledger-marker">{entry.marker}</p>
              <h3>{entry.title}</h3>
            </div>
            <p class="ledger-role">{entry.role}</p>
            <p>{entry.note}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="notes-section" aria-labelledby="notes-title">
    <div class="section-heading">
      <p class="section-kicker">Notes index</p>
      <h2 id="notes-title">Start with the post that still has dirt under its nails.</h2>
    </div>

    <div class="note-strip">
      {
        publishedPosts.slice(0, 3).map((post) => {
          const date = new Intl.DateTimeFormat('en-US', {
            month: 'short',
            year: 'numeric',
          }).format(post.data.publishedDate);

          return (
            <a href={`/blog/${post.id}`} class="note-strip-link">
              {post.data.image && <img src={`/${post.data.image}`} alt="" loading="lazy" />}
              <span>{date}</span>
              <strong>{post.data.title}</strong>
            </a>
          );
        })
      }
    </div>
  </section>

  <section class="contact-section" id="contact" aria-labelledby="contact-title">
    <div class="section-heading">
      <p class="section-kicker">Signal</p>
      <h2 id="contact-title">If something here maps to a conversation, send a note.</h2>
      <p>
        Email is best. GitHub and LinkedIn are there for the usual context check.
      </p>
    </div>

    <div class="contact-grid">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            class="contact-card"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
          >
            <span>{link.label}</span>
            <span aria-hidden="true">↗</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .desk-hero,
  .now-section,
  .work-section,
  .notes-section,
  .contact-section {
    padding-block: clamp(3rem, 8vw, 7rem);
  }

  .desk-hero {
    display: grid;
    min-height: min(760px, calc(100vh - 7rem));
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    border-bottom: var(--rule);
  }

  .desk-copy {
    display: grid;
    gap: var(--spacing-lg);
  }

  .desk-copy h1 {
    max-width: 8ch;
  }

  .hero-statement {
    max-width: 44rem;
    color: var(--text-primary);
    font-size: clamp(1.2rem, 2.2vw, 1.55rem);
    line-height: 1.45;
  }

  .hero-routes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .featured-note {
    display: grid;
    align-content: start;
    gap: var(--spacing-md);
  }

  .hero-slip {
    position: relative;
    display: grid;
    min-height: clamp(23rem, 43vw, 32rem);
    align-content: end;
    gap: 0.7rem;
    overflow: hidden;
    padding: clamp(1.15rem, 3vw, 2rem);
    border: var(--rule);
    border-radius: var(--radius-card);
    background:
      linear-gradient(color-mix(in oklch, var(--border-color) 23%, transparent) 1px, transparent 1px) 0 0 / 100% 2.15rem,
      color-mix(in oklch, var(--bg-surface) 88%, var(--annotation) 5%);
    color: var(--text-secondary);
    text-decoration: none;
    box-shadow: var(--paper-shadow);
  }

  .hero-slip::before {
    position: absolute;
    top: -1px;
    right: -1px;
    width: 4.3rem;
    height: 4.3rem;
    border-bottom: var(--rule);
    border-left: var(--rule);
    background: color-mix(in oklch, var(--bg-main) 82%, var(--annotation) 9%);
    content: "";
    clip-path: polygon(100% 0, 100% 100%, 0 0);
  }

  .hero-slip::after {
    position: absolute;
    top: 1.05rem;
    left: 1.05rem;
    width: 5rem;
    height: 1.9rem;
    border: 1px solid color-mix(in oklch, var(--annotation) 52%, transparent);
    border-radius: 50%;
    content: "";
    opacity: 0.32;
    transform: rotate(-8deg);
  }

  .hero-slip:hover {
    border-color: var(--accent);
  }

  .slip-label,
  .slip-date,
  .slip-margin {
    font-family: var(--font-sans);
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 740;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .slip-label {
    position: absolute;
    top: 1.1rem;
    left: 1.1rem;
    color: var(--annotation);
    font-size: 0.68rem;
  }

  .slip-date {
    width: fit-content;
    padding: 0.18rem 0.42rem;
    border: 1px solid color-mix(in oklch, var(--border-color) 72%, transparent);
    border-radius: var(--radius-chip);
    color: var(--text-faint);
    font-size: 0.72rem;
  }

  .hero-slip strong {
    max-width: 14ch;
    color: var(--text-primary);
    font-family: var(--font-serif);
    font-size: clamp(2.05rem, 5vw, 3.85rem);
    line-height: 0.95;
  }

  .slip-copy {
    max-width: 34rem;
    color: var(--text-primary);
    font-size: clamp(1rem, 1.6vw, 1.16rem);
    line-height: 1.55;
  }

  .slip-margin {
    max-width: 18rem;
    margin-top: 0.35rem;
    color: var(--annotation);
    font-size: 0.7rem;
    line-height: 1.45;
  }

  .note-meta,
  .ledger-marker,
  .note-strip-link span {
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 740;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .section-heading {
    display: grid;
    gap: 0.8rem;
    margin-bottom: clamp(1.5rem, 4vw, 3rem);
  }

  .section-heading h2 {
    max-width: 18ch;
  }

  .section-heading p:not(.section-kicker) {
    font-size: 1.08rem;
  }

  .note-columns {
    display: grid;
    gap: var(--spacing-lg);
    max-width: 64rem;
  }

  .note-columns p {
    color: var(--text-primary);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1.52;
  }

  .ledger-list {
    display: grid;
    border-top: var(--rule);
  }

  .ledger-entry {
    display: grid;
    gap: var(--spacing-md);
    padding: clamp(1.25rem, 3.5vw, 2.25rem) 0;
    border-bottom: var(--rule);
  }

  .ledger-number {
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
  }

  .ledger-role {
    color: var(--text-primary);
  }

  .note-strip,
  .contact-grid {
    display: grid;
    gap: var(--spacing-md);
  }

  .note-strip-link {
    position: relative;
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr);
    gap: 0.7rem 1rem;
    align-items: center;
    min-height: 112px;
    padding: 0.7rem;
    border: var(--rule);
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--bg-surface) 82%, transparent);
    color: var(--text-primary);
    text-decoration: none;
  }

  .note-strip-link::after {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    width: 1.2rem;
    height: 1.2rem;
    border-top: var(--rule);
    border-right: var(--rule);
    content: "";
    opacity: 0.7;
  }

  .note-strip-link:hover {
    border-color: var(--annotation);
  }

  .note-strip-link img {
    grid-row: span 2;
    width: 96px;
    height: 96px;
    border-radius: calc(var(--radius-card) - 0.1rem);
    object-fit: cover;
    filter: saturate(0.78) contrast(1.04);
  }

  .note-strip-link strong {
    align-self: start;
    font-size: 1.2rem;
    line-height: 1.15;
  }

  .contact-card {
    display: flex;
    min-height: 4.5rem;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    border: var(--rule);
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--bg-surface) 82%, transparent);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-weight: 700;
    text-decoration: none;
  }

  .contact-card:hover {
    border-color: var(--accent);
  }

  @media (min-width: 820px) {
    .desk-hero {
      grid-template-columns: minmax(0, 1.15fr) minmax(300px, 0.75fr);
    }

    .note-columns,
    .note-strip,
    .contact-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .ledger-entry {
      grid-template-columns: 4rem minmax(180px, 0.8fr) minmax(240px, 1fr) minmax(240px, 1.1fr);
      align-items: start;
    }
  }

  @media (min-width: 1180px) {
    .desk-hero {
      width: min(calc(100vw - 4rem), 1360px);
      margin-inline: 50%;
      transform: translateX(-50%);
      grid-template-columns: minmax(0, 1.22fr) minmax(360px, 0.78fr);
    }
  }

  @media (min-width: 820px) and (max-width: 1020px) {
    .desk-hero {
      min-height: auto;
      padding-block: clamp(3.25rem, 8vw, 5rem);
      grid-template-columns: minmax(0, 1fr) minmax(280px, 0.82fr);
    }

    .now-section {
      padding-top: clamp(2.5rem, 7vw, 4rem);
    }
  }

  @media (max-width: 640px) {
    .note-strip-link {
      grid-template-columns: 76px minmax(0, 1fr);
      min-height: 96px;
    }

    .note-strip-link img {
      width: 76px;
      height: 76px;
    }
  }
</style>
