---
import BaseLayout from './BaseLayout.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  publishedDate: Date;
  author: string;
  tags: string[];
  ogImage?: string;
  ogImageAlt?: string;
}

const { title, description, canonicalUrl, publishedDate, author, tags, ogImage, ogImageAlt } =
  Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(publishedDate);
---
<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt ?? `${title} - Jordan Gopie field note.`}
  ogType="article"
>
  <article class="blog-article">
    <header class="post-intro">
      <a href="/blog" class="back-link">Notes index</a>
      <p class="post-eyebrow">Field note</p>
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
    </header>
    <aside class="post-rail" aria-label="Post filing details">
      <span class="rail-label">Filed note</span>
      <div class="post-meta">
        <span>{author}</span>
        <span aria-hidden="true">/</span>
        <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
      </div>
      <ul class="post-tags" aria-label="Post topics">
        {
          tags.map((tag) => (
            <li>{tag}</li>
          ))
        }
      </ul>
    </aside>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    display: grid;
    gap: clamp(1.35rem, 4vw, 3rem);
    width: min(100%, 68rem);
    margin: 0 auto;
    padding-block: clamp(2rem, 5vw, 4.5rem);
  }

  .post-intro {
    display: grid;
    gap: clamp(0.75rem, 2vw, var(--spacing-md));
  }

  .back-link {
    width: fit-content;
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--annotation);
  }

  .post-intro h1 {
    max-width: 11ch;
    font-size: clamp(2.6rem, 8vw, 5.7rem);
    line-height: 0.95;
  }

  .post-description {
    max-width: 42rem;
    color: var(--text-primary);
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.5;
  }

  .post-rail {
    position: relative;
    display: grid;
    gap: var(--spacing-md);
    overflow: hidden;
    padding: var(--spacing-md);
    border: var(--rule);
    border-radius: var(--radius-card);
    background:
      linear-gradient(color-mix(in oklch, var(--border-color) 18%, transparent) 1px, transparent 1px) 0 0 / 100% 2rem,
      color-mix(in oklch, var(--bg-surface) 84%, transparent);
  }

  .post-rail::after {
    position: absolute;
    top: -1px;
    right: -1px;
    width: 2.5rem;
    height: 2.5rem;
    border-bottom: var(--rule);
    border-left: var(--rule);
    background: color-mix(in oklch, var(--bg-main) 80%, var(--annotation) 8%);
    content: "";
    clip-path: polygon(100% 0, 100% 100%, 0 0);
  }

  .rail-label {
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.86rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-tags li {
    display: inline-flex;
    align-items: center;
    min-height: 1.85rem;
    padding: 0.26rem 0.58rem;
    border: var(--rule);
    border-radius: var(--radius-chip);
    background: color-mix(in oklch, var(--bg-surface) 76%, transparent);
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 690;
    letter-spacing: 0.05em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .prose {
    width: min(100%, 48rem);
  }

  @media (min-width: 920px) {
    .blog-article {
      grid-template-columns: minmax(12rem, 0.38fr) minmax(0, 48rem);
      align-items: start;
    }

    .post-intro,
    .prose {
      grid-column: 2;
    }

    .post-rail {
      position: sticky;
      top: 5.5rem;
      grid-column: 1;
      grid-row: 1 / span 2;
    }
  }
</style>

<style is:global>
    @reference "../styles/global.css";

    .prose {
        color: var(--text-secondary);
        font-family: var(--font-serif);
    }

    .prose h1,
    .prose h2,
    .prose h3 {
        color: var(--text-primary);
    }

    .prose h1 {
        font-size: clamp(2.25rem, 6vw, 4rem);
        line-height: 1;
        margin-bottom: var(--spacing-xl);
    }

    .prose h2 {
        font-size: clamp(1.75rem, 4vw, 2.65rem);
        line-height: 1.05;
        margin-bottom: var(--spacing-md);
        margin-top: var(--spacing-2xl);
    }

    .prose h3 {
        font-size: clamp(1.25rem, 3vw, 1.65rem);
        line-height: 1.15;
        margin-bottom: var(--spacing-sm);
        margin-top: var(--spacing-lg);
    }

    .prose p {
        color: var(--text-secondary);
        font-size: 1.08rem;
        line-height: 1.78;
        margin-bottom: var(--spacing-md);
    }

    .prose p:first-child {
        color: var(--text-primary);
        font-size: 1.17rem;
    }

    .prose a {
        color: var(--accent);
    }

    .prose ul,
    .prose ol {
        display: grid;
        gap: 0.45rem;
        margin: var(--spacing-lg) 0;
        padding-left: 1.2rem;
    }

    .prose li {
        color: var(--text-secondary);
        line-height: 1.75;
        padding-left: 0.25rem;
    }

    .prose blockquote {
        margin: var(--spacing-xl) 0;
        padding: var(--spacing-md) var(--spacing-lg);
        border: var(--rule);
        border-radius: var(--radius-card);
        background: color-mix(in oklch, var(--bg-surface) 76%, transparent);
        color: var(--text-primary);
    }

    .prose code {
        font-family: var(--font-mono);
        color: var(--annotation);
    }

    .prose pre {
        margin: var(--spacing-lg) 0;
        padding: var(--spacing-lg);
        overflow-x: auto;
        border: var(--rule);
        border-radius: var(--radius-card);
        background: var(--bg-inset);
    }

    .prose pre code {
        padding: 0;
        border: none;
        background: none;
    }

    .prose img {
        border: var(--rule);
        border-radius: var(--radius-card);
        filter: saturate(0.82) contrast(1.03);
    }
</style>
