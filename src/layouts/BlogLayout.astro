---
import BaseLayout from './BaseLayout.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  publishedDate: Date;
  author: string;
  tags: string[];
  ogImage?: string;
}

const { title, description, canonicalUrl, publishedDate, author, tags, ogImage } =
  Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(publishedDate);
---
<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
>
  <article class="blog-article">
    <header class="post-intro">
      <span class="post-eyebrow">Journal</span>
      <div class="post-meta">
        <span>{author}</span>
        <span aria-hidden="true">|</span>
        <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
      </div>
      <ul class="post-tags" aria-label="Post topics">
        {
          tags.map((tag) => (
            <li>{tag}</li>
          ))
        }
      </ul>
    </header>
    <div class="prose prose-lg max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-article {
    max-width: 48rem;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-md);
  }

  .post-intro {
    display: grid;
    gap: 0.7rem;
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
  }

  .post-eyebrow {
    color: var(--color-electric-blue);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-tags li {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-chip);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-secondary);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    line-height: 1.2;
    background: rgba(255, 255, 255, 0.02);
    text-transform: uppercase;
  }

  [data-theme='light'] .post-tags li {
    border-color: rgba(17, 24, 39, 0.08);
    background: rgba(17, 24, 39, 0.03);
  }

  @media (max-width: 640px) {
    .post-tags {
      gap: 0.4rem;
    }

    .post-tags li {
      min-height: 1.9rem;
      padding: 0.28rem 0.65rem;
    }
  }
</style>

<style is:global>
    @reference "../styles/global.css";

    /* Blog prose styling with design system colors */
    .prose h1 {
        font-size: 2.5rem;
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.02em;
        margin-bottom: var(--spacing-xl);
        background: linear-gradient(135deg, #00C2FF 0%, #8A2EFF 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .prose h2 {
        font-size: 1.75rem;
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.01em;
        margin-bottom: var(--spacing-md);
        margin-top: var(--spacing-2xl);
        color: var(--text-primary);
    }

    .prose h3 {
        font-size: 1.25rem;
        font-weight: 500;
        line-height: 1.3;
        margin-bottom: var(--spacing-sm);
        margin-top: var(--spacing-lg);
        color: var(--text-primary);
    }

    .prose p {
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: var(--spacing-md);
    }

    /* Enhanced list styling */
    .prose ul {
        margin: var(--spacing-lg) 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        list-style-type: none !important;
        padding-left: 0 !important;
    }

    .prose ul li {
        padding-left: var(--spacing-md);
        position: relative;
        display: block !important;
        margin: 0 !important;
        color: var(--text-secondary);
    }

    .prose ul li::before {
        content: "•";
        position: absolute;
        left: 0;
        color: var(--color-electric-blue);
    }

    /* Force list items to break onto new lines */
    .prose ul li p {
        display: block !important;
        margin: 0 !important;
    }

    /* Code blocks */
    .prose code {
        font-family: var(--font-mono);
        font-size: 0.875rem;
        background-color: var(--bg-surface);
        color: var(--color-electric-blue);
        padding: 2px 6px;
        border-radius: 4px;
        border: 1px solid var(--border-color);
    }

    .prose pre {
        background-color: var(--bg-surface);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-card);
        padding: var(--spacing-lg);
        overflow-x: auto;
        margin: var(--spacing-lg) 0;
    }

    .prose pre code {
        background: none;
        border: none;
        padding: 0;
        color: var(--text-primary);
    }

    /* Links */
    .prose a {
        color: var(--color-electric-blue);
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color 0.2s ease;
    }

    .prose a:hover {
        color: var(--color-vibrant-purple);
    }

    /* Additional spacing and typography refinements */
    .prose {
        font-size: 1rem;
        line-height: 1.7;
    }

    .prose > * + * {
        margin-top: var(--spacing-lg);
    }

    .prose blockquote {
        padding-left: var(--spacing-lg);
        border-left: 4px solid var(--color-electric-blue);
        font-style: italic;
        color: var(--text-secondary);
        margin: var(--spacing-lg) 0;
    }

    .prose img {
        border-radius: var(--radius-card);
        margin: var(--spacing-xl) 0;
    }

    /* Reset any Tailwind prose list styles that might interfere */
    .prose ul > li::marker {
        content: none !important;
    }

    .prose ul > li {
        padding-left: var(--spacing-md) !important;
        color: var(--text-secondary);
    }

    .prose strong {
        color: var(--text-primary);
        font-weight: 600;
    }
</style>
