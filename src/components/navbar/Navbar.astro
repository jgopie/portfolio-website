---
import { siteConfig } from '../../data/site';

const pathname = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Index', isCurrent: pathname === '/' },
  { href: '/blog', label: 'Notes', isCurrent: pathname === '/blog' || pathname.startsWith('/blog/') },
  { href: '/#work-ledger', label: 'Ledger', isCurrent: false },
  { href: '/#contact', label: 'Signal', isCurrent: false },
];
---
<nav class="navbar" aria-label="Primary">
    <a class="navbar-brand" href="/" aria-label="Jordan Gopie home">
        <span>JG</span>
        <span>field notes</span>
    </a>

    <div class="navbar-actions">
        <ul class="desktop-list">
            {
                navLinks.map((link) => (
                    <li>
                        <a href={link.href} aria-current={link.isCurrent ? 'page' : undefined}>
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>

        <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Switch to light theme"
            title="Toggle theme"
        >
            <span class="theme-toggle__mark" aria-hidden="true"></span>
        </button>

        <button
            type="button"
            class="mobile-menu-btn"
            id="mobile-menu-btn"
            aria-label="Toggle menu"
            aria-expanded="false"
            aria-controls="mobile-navigation"
        >
            <span aria-hidden="true"></span>
        </button>
    </div>

    <div class="mobile-panel" id="mobile-navigation" aria-hidden="true">
        <ul class="mobile-list">
            {
                navLinks.map((link) => (
                    <li>
                        <a href={link.href} aria-current={link.isCurrent ? 'page' : undefined}>
                            {link.label}
                        </a>
                    </li>
                ))
            }
            <li>
                <a href={`mailto:${siteConfig.contactEmail}`}>Direct signal</a>
            </li>
        </ul>
    </div>
</nav>

<script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-navigation');
    const navbar = document.querySelector('.navbar');
    const mobileLinks = mobileMenu?.querySelectorAll('a');
    const themeToggle = document.getElementById('theme-toggle');

    let isOpen = false;

    function syncMenu() {
        mobileMenu?.classList.toggle('open', isOpen);
        mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
        menuBtn?.setAttribute('aria-expanded', String(isOpen));
    }

    function closeMenu() {
        if (!isOpen) {
            return;
        }

        isOpen = false;
        syncMenu();
    }

    function getStoredTheme(): string | null {
        return localStorage.getItem('theme');
    }

    function setTheme(theme: string) {
        document.documentElement.classList.add('theme-transition');
        document.documentElement.setAttribute('data-theme', theme);
        const label = theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme';
        themeToggle?.setAttribute('aria-label', label);
        localStorage.setItem('theme', theme);
        setTimeout(() => {
            document.documentElement.classList.remove('theme-transition');
        }, 260);
    }

    function toggleTheme() {
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
        setTheme(currentTheme === 'dark' ? 'light' : 'dark');
    }

    function initTheme() {
        const theme = getStoredTheme() || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        const label = theme === 'dark' ? 'Switch to light theme' : 'Switch to dark theme';
        themeToggle?.setAttribute('aria-label', label);
    }

    menuBtn?.addEventListener('click', () => {
        isOpen = !isOpen;
        syncMenu();
    });

    mobileLinks?.forEach((link) => {
        link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
            closeMenu();
        }
    });

    document.addEventListener('click', (event) => {
        if (!isOpen || !(event.target instanceof Node)) {
            return;
        }

        if (!navbar?.contains(event.target)) {
            closeMenu();
        }
    });

    themeToggle?.addEventListener('click', toggleTheme);

    initTheme();
    syncMenu();
</script>

<style>
.navbar {
    position: relative;
    z-index: 20;
    display: flex;
    width: min(100% - 2rem, 1180px);
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-lg);
    margin: 0 auto;
    padding: 1rem 0 0.25rem;
    font-family: var(--font-sans);
}

.navbar-brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.65rem;
    color: var(--text-primary);
    text-decoration: none;
}

.navbar-brand span:first-child {
    display: inline-grid;
    min-width: 2.35rem;
    min-height: 2.35rem;
    place-items: center;
    border: var(--rule);
    border-radius: 0.3rem;
    color: var(--annotation);
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 760;
}

.navbar-brand span:last-child {
    color: var(--text-faint);
    font-size: 0.78rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}

.navbar-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.desktop-list,
.mobile-list {
    list-style: none;
}

.desktop-list {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.25rem;
    border: var(--rule);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--bg-surface) 76%, transparent);
}

.desktop-list a,
.mobile-list a {
    display: inline-flex;
    color: var(--text-secondary);
    font-size: 0.82rem;
    font-weight: 680;
    text-decoration: none;
}

.desktop-list a {
    padding: 0.5rem 0.78rem;
    border-radius: var(--radius-pill);
}

.desktop-list a:hover,
.desktop-list a[aria-current="page"] {
    background: color-mix(in oklch, var(--accent) 12%, transparent);
    color: var(--text-primary);
}

.theme-toggle,
.mobile-menu-btn {
    display: inline-grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    border: var(--rule);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--bg-surface) 76%, transparent);
    color: var(--text-primary);
    cursor: pointer;
}

.theme-toggle:hover,
.mobile-menu-btn:hover {
    border-color: var(--accent);
}

.theme-toggle__mark {
    display: block;
    width: 0.9rem;
    height: 0.9rem;
    border: 2px solid var(--annotation);
    border-radius: var(--radius-pill);
    background: var(--annotation);
    box-shadow: inset -0.3rem -0.15rem 0 var(--bg-surface);
}

[data-theme="light"] .theme-toggle__mark {
    border-color: var(--accent);
    background: transparent;
    box-shadow: inset 0.32rem 0 0 var(--accent);
}

.mobile-menu-btn {
    display: none;
}

.mobile-menu-btn span,
.mobile-menu-btn span::before,
.mobile-menu-btn span::after {
    display: block;
    width: 1rem;
    height: 2px;
    border-radius: var(--radius-pill);
    background: var(--text-primary);
    content: "";
}

.mobile-menu-btn span {
    position: relative;
}

.mobile-menu-btn span::before,
.mobile-menu-btn span::after {
    position: absolute;
    left: 0;
}

.mobile-menu-btn span::before {
    top: -0.35rem;
}

.mobile-menu-btn span::after {
    top: 0.35rem;
}

.mobile-panel {
    display: none;
}

@media (max-width: 760px) {
    .navbar {
        width: min(100% - 1rem, 1180px);
        padding-top: 0.75rem;
    }

    .navbar-brand span:last-child {
        display: none;
    }

    .desktop-list {
        display: none;
    }

    .mobile-menu-btn {
        display: inline-grid;
    }

    .mobile-panel {
        position: absolute;
        top: calc(100% + 0.6rem);
        right: 0;
        left: 0;
        display: none;
        padding: 0.75rem;
        border: var(--rule);
        border-radius: var(--radius-card);
        background: var(--bg-surface);
        box-shadow: var(--paper-shadow);
    }

    .mobile-panel.open {
        display: block;
    }

    .mobile-list {
        display: grid;
        gap: 0.35rem;
    }

    .mobile-list a {
        width: 100%;
        padding: 0.72rem 0.85rem;
        border-radius: var(--radius-button);
    }

    .mobile-list a:hover,
    .mobile-list a[aria-current="page"] {
        background: color-mix(in oklch, var(--accent) 12%, transparent);
        color: var(--text-primary);
    }
}
</style>
