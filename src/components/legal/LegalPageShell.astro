---
interface MetaItem {
  label: string;
  value: string;
  href?: string;
}

interface RelatedLink {
  label: string;
  href: string;
}

interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  metaItems: readonly MetaItem[];
  relatedLinks: readonly RelatedLink[];
  footerNote: string;
}

const { eyebrow, title, summary, metaItems, relatedLinks, footerNote } =
  Astro.props as Props;
---

<section class="legal-hero" aria-labelledby="legal-page-title">
  <span class="legal-eyebrow">{eyebrow}</span>
  <div class="legal-hero-grid">
    <div class="legal-copy">
      <h1 id="legal-page-title">{title}</h1>
      <p>{summary}</p>
      <nav class="legal-related-links" aria-label="Related legal pages">
        {
          relatedLinks.map((link) => (
            <a href={link.href} class="legal-related-link">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
    <aside class="legal-meta-panel" aria-label="Page metadata">
      {
        metaItems.map((item) => (
          <div class="legal-metric">
            <span class="legal-metric-label">{item.label}</span>
            {
              item.href ? (
                <a href={item.href} class="legal-metric-value">
                  {item.value}
                </a>
              ) : (
                <span class="legal-metric-value">{item.value}</span>
              )
            }
          </div>
        ))
      }
    </aside>
  </div>
</section>

<section class="legal-content-grid">
  <div class="legal-main">
    <slot />
  </div>
  <aside class="legal-aside">
    <slot name="aside" />
  </aside>
</section>

<footer class="legal-footer">
  <p>{footerNote}</p>
</footer>

<style>
  .legal-hero {
    display: grid;
    gap: var(--spacing-lg);
    padding-block: clamp(2rem, 6vw, 4rem);
    border-bottom: var(--rule);
  }

  .legal-eyebrow {
    display: inline-flex;
    width: fit-content;
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .legal-hero-grid,
  .legal-content-grid {
    display: grid;
    gap: var(--spacing-lg);
  }

  .legal-hero-grid {
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.85fr);
    align-items: start;
  }

  .legal-copy {
    display: grid;
    gap: var(--spacing-md);
  }

  .legal-copy h1 {
    max-width: 11ch;
    font-size: clamp(3rem, 8vw, 6rem);
  }

  .legal-copy p {
    max-width: 62ch;
    color: var(--text-primary);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.55;
  }

  .legal-related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .legal-related-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.45rem;
    padding: 0.55rem 0.75rem;
    border: var(--rule);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--bg-surface) 72%, transparent);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 680;
    text-decoration: none;
  }

  .legal-related-link:hover,
  .legal-related-link:focus-visible {
    border-color: var(--accent);
    color: var(--accent);
  }

  .legal-meta-panel,
  .legal-section,
  .legal-aside-card {
    position: relative;
    overflow: hidden;
    border: var(--rule);
    border-radius: var(--radius-card);
    background:
      linear-gradient(color-mix(in oklch, var(--border-color) 13%, transparent) 1px, transparent 1px) 0 0 / 100% 2.15rem,
      color-mix(in oklch, var(--bg-surface) 86%, transparent);
  }

  .legal-meta-panel::after,
  :global(.legal-section)::after,
  :global(.legal-aside-card)::after {
    position: absolute;
    top: -1px;
    right: -1px;
    width: 2.35rem;
    height: 2.35rem;
    border-bottom: var(--rule);
    border-left: var(--rule);
    background: color-mix(in oklch, var(--bg-main) 82%, var(--annotation) 7%);
    content: "";
    clip-path: polygon(100% 0, 100% 100%, 0 0);
  }

  .legal-meta-panel {
    display: grid;
    gap: 0.7rem;
    padding: var(--spacing-md);
  }

  .legal-metric {
    display: grid;
    gap: 0.25rem;
    padding: 0.85rem;
    border: 1px solid color-mix(in oklch, var(--border-color) 70%, transparent);
    border-radius: calc(var(--radius-card) - 0.12rem);
    background: color-mix(in oklch, var(--bg-inset) 46%, transparent);
  }

  .legal-metric-label {
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 740;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .legal-metric-value {
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 640;
    line-height: 1.35;
  }

  .legal-content-grid {
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.85fr);
    margin-top: var(--spacing-xl);
  }

  .legal-main,
  .legal-aside {
    display: grid;
    gap: var(--spacing-lg);
    align-content: start;
  }

  .legal-footer {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-md);
    border-top: var(--rule);
  }

  .legal-footer p {
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.88rem;
  }

  :global(.legal-section),
  :global(.legal-aside-card) {
    display: grid;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
  }

  :global(.legal-section h2),
  :global(.legal-aside-card h2) {
    margin-bottom: 0;
    font-size: clamp(1.45rem, 3vw, 2.15rem);
  }

  :global(.legal-section h3) {
    margin-bottom: 0;
    font-size: 1.05rem;
  }

  :global(.legal-section p),
  :global(.legal-section li),
  :global(.legal-aside-card p),
  :global(.legal-aside-card li) {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  :global(.legal-section ul),
  :global(.legal-section ol),
  :global(.legal-aside-card ul) {
    display: grid;
    gap: 0.6rem;
    margin: 0;
    padding-left: 1.2rem;
  }

  :global(.legal-section ol) {
    padding-left: 1.35rem;
  }

  :global(.legal-callout) {
    padding: 1rem;
    border: 1px solid color-mix(in oklch, var(--annotation) 42%, var(--border-color));
    border-radius: var(--radius-card);
    background: color-mix(in oklch, var(--annotation) 11%, var(--bg-surface));
    color: var(--text-primary);
  }

  @media (max-width: 860px) {
    .legal-hero-grid,
    .legal-content-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .legal-meta-panel,
    :global(.legal-section),
    :global(.legal-aside-card) {
      animation: legal-rise-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
    }
  }

  @keyframes legal-rise-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
