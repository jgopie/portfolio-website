---
import { Image } from 'astro:assets';
import githubIcon from '/public/github.svg';
import linkedinIcon from '/public/linkedin.svg';
import { siteConfig } from '../../data/site';
---
<footer class="footer">
    <div class="footer-copy">
        <p class="footer-kicker">Available for full-stack roles and contract work.</p>
        <p>
            I build product-focused web apps, automation systems, and reliable backend services.
            Reach out if you want a walkthrough of selected client work or project experience.
        </p>
    </div>
    <div class="svgCard" aria-label="Social and contact links">
        <a href={`mailto:${siteConfig.contactEmail}`} aria-label="Email Jordan Gopie">
            <span class="contact-badge">Email</span>
        </a>
        <a href={siteConfig.githubUrl} aria-label="Jordan Gopie's GitHub" target="_blank" rel="noreferrer">
            <Image src={githubIcon} alt="" width={20} height={20} aria-hidden="true" />
        </a>
        <a href={siteConfig.linkedinUrl} aria-label="Jordan Gopie's LinkedIn" target="_blank" rel="noreferrer">
            <Image src={linkedinIcon} alt="" width={20} height={20} aria-hidden="true" />
        </a>
    </div>
    <p>&copy; Jordan Gopie {new Date().getFullYear()}</p>
</footer>

<style>
.footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-top: 1px solid var(--border-color);
    background-color: var(--bg-main);
    width: 100%;
}

.footer-copy {
    display: grid;
    gap: 0.5rem;
    max-width: 42rem;
    text-align: center;
}

.footer-kicker {
    color: var(--text-primary);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.svgCard {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    align-items: center;
    justify-content: center;
}

.svgCard a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 0.95rem;
    border-radius: var(--radius-button);
    border: 1px solid var(--border-color);
    background-color: var(--bg-surface);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.svgCard a:hover {
    border-color: var(--color-electric-blue);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
}

.contact-badge {
    color: var(--text-primary);
    font-size: 0.95rem;
    font-weight: 600;
}

.svgCard img {
    width: 20px;
    height: 20px;
    filter: invert(1);
    opacity: 0.8;
    transition: opacity 0.2s ease;
}

.svgCard a:hover img {
    opacity: 1;
}

.footer p {
    color: var(--text-secondary);
    font-size: 0.875rem;
}
</style>
