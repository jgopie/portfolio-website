---
import { Image } from 'astro:assets';
import githubIcon from '/public/github.svg';
import linkedinIcon from '/public/linkedin.svg';
---
<footer class="footer">
    <div class="svgCard">
        <a href="https://github.com/jgopie" aria-label="GitHub">
            <Image src={githubIcon} alt="GitHub" width={20} height={20} />
        </a>
        <a href="https://www.linkedin.com/in/jordan-gopie-429904239/" aria-label="LinkedIn">
            <Image src={linkedinIcon} alt="LinkedIn" width={20} height={20} />
        </a>
    </div>
    <p>© Jordan Gopie {new Date().getFullYear()}</p>
</footer>

<style>
.footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-xl) var(--spacing-lg);
    border-top: 1px solid var(--border-color);
    background-color: var(--bg-main);
    width: 100%;
}

.svgCard {
    display: flex;
    gap: var(--spacing-lg);
}

.svgCard a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-button);
    border: 1px solid var(--border-color);
    background-color: var(--bg-surface);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.svgCard a:hover {
    border-color: var(--color-electric-blue);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-2px);
}

.svgCard img {
    width: 20px;
    height: 20px;
    filter: invert(1);
    opacity: 0.8;
    transition: opacity 0.2s ease;
}

.svgCard a:hover img {
    opacity: 1;
}

.footer p {
    color: var(--text-secondary);
    font-size: 0.875rem;
}
</style>

