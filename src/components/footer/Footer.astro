---
import { Image } from 'astro:assets';
import githubIcon from '/public/github.svg';
import linkedinIcon from '/public/linkedin.svg';
import { siteConfig } from '../../data/site';
---
<footer class="footer">
    <div class="footer-copy">
        <p class="footer-kicker">End matter</p>
        <p>
            Notes, build scars, and project traces. Signal is open, but the better
            first move is still reading one filed note.
        </p>
    </div>

    <nav class="footer-links" aria-label="Footer">
        <a href="/blog">Notes</a>
        <a href={`mailto:${siteConfig.contactEmail}`}>Signal</a>
        <a href={siteConfig.githubUrl} target="_blank" rel="noreferrer">
            <Image src={githubIcon} alt="" width={18} height={18} aria-hidden="true" />
            GitHub
        </a>
        <a href={siteConfig.linkedinUrl} target="_blank" rel="noreferrer">
            <Image src={linkedinIcon} alt="" width={18} height={18} aria-hidden="true" />
            LinkedIn
        </a>
    </nav>

    <p class="footer-fineprint">&copy; Jordan Gopie {new Date().getFullYear()}</p>
</footer>

<style>
.footer {
    display: grid;
    width: min(100% - 2rem, 1180px);
    gap: var(--spacing-lg);
    margin: var(--spacing-2xl) auto 0;
    padding: var(--spacing-xl) 0;
    border-top: var(--rule);
}

.footer-copy {
    display: grid;
    gap: 0.45rem;
}

.footer-kicker {
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 760;
    letter-spacing: 0.12em;
    text-transform: uppercase;
}

.footer-copy p:not(.footer-kicker) {
    max-width: 40rem;
}

.footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
}

.footer-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    min-height: 2.4rem;
    padding: 0.45rem 0.72rem;
    border: var(--rule);
    border-radius: var(--radius-pill);
    background: color-mix(in oklch, var(--bg-surface) 72%, transparent);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 680;
    text-decoration: none;
}

.footer-links a:hover {
    border-color: var(--annotation);
    color: var(--annotation);
}

.footer-links img {
    width: 1.1rem;
    height: 1.1rem;
    filter: invert(1);
    opacity: 0.72;
}

[data-theme="light"] .footer-links img {
    filter: invert(0);
}

.footer-fineprint {
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.78rem;
}
</style>
