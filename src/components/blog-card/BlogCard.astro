---
interface Props {
  title: string;
  excerpt: string;
  image: string | undefined;
  publishedDate: Date;
  slug: string;
  tags: string[];
}

const { title, excerpt, image, publishedDate, slug, tags } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(publishedDate);
---
<a href={`/blog/${slug}`} class="blog-card-link">
    <article class="blog-container">
        {image && (
            <img
                class="blogImage"
                src={`/${image}`}
                alt=""
                width="120"
                height="120"
                loading="lazy"
                aria-hidden="true"
            />
        )}
        <div class="link-container">
            <div class="blog-meta">
                <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
                <span aria-hidden="true">|</span>
                <span>{tags.join(' / ')}</span>
            </div>
            <h2>{title}</h2>
            <p class="blog-excerpt">{excerpt}</p>
        </div>
    </article>
</a>

<style>
.blog-container {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    padding: var(--spacing-lg);
    background-color: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-card);
    transition: box-shadow 0.3s ease, border-color 0.3s ease, transform 0.2s ease;
    width: 100%;
    max-width: 800px;
}

.blog-container:hover {
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-electric-blue);
    transform: translateY(-2px);
}

.blogImage {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: var(--radius-button);
    flex-shrink: 0;
}

.link-container {
    flex: 1;
    display: grid;
    gap: 0.75rem;
}

.blog-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: var(--text-secondary);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.link-container h2 {
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.4;
    transition: color 0.2s ease;
}

.blog-excerpt {
    margin: 0;
    color: var(--text-secondary);
    line-height: 1.7;
}

.blog-container:hover .link-container h2 {
    color: var(--color-electric-blue);
}

.blog-card-link {
    text-decoration: none;
    display: block;
}

.blog-card-link:focus-visible .blog-container {
    border-color: var(--color-electric-blue);
    box-shadow: var(--shadow-card-hover);
}

@media (max-width: 640px) {
    .blog-container {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--spacing-md);
    }
    
    .blogImage {
        width: 100%;
        height: 200px;
    }
}
</style>
