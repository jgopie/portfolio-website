---
interface Props {
  title: string;
  excerpt: string;
  image: string | undefined;
  publishedDate: Date;
  slug: string;
  tags: string[];
  index: number;
}

const { title, excerpt, image, publishedDate, slug, tags, index } = Astro.props;
const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(publishedDate);
---
<a href={`/blog/${slug}`} class="note-card-link">
    <article class="note-card">
        <span class="note-index">{String(index).padStart(2, '0')}</span>
        <div class="note-copy">
            <div class="note-meta">
                <time datetime={publishedDate.toISOString()}>{formattedDate}</time>
                <span>{tags.slice(0, 2).join(' / ')}</span>
            </div>
            <h2>{title}</h2>
            <p>{excerpt}</p>
        </div>
        {image && (
            <img
                class="note-image"
                src={`/${image}`}
                alt=""
                width="140"
                height="110"
                loading="lazy"
                aria-hidden="true"
            />
        )}
    </article>
</a>

<style>
.note-card-link {
    display: block;
    color: inherit;
    text-decoration: none;
}

.note-card {
    position: relative;
    display: grid;
    gap: var(--spacing-md);
    align-items: start;
    overflow: hidden;
    padding: clamp(1rem, 2.6vw, 1.55rem);
    border: var(--rule);
    border-radius: var(--radius-card);
    background:
        linear-gradient(color-mix(in oklch, var(--border-color) 18%, transparent) 1px, transparent 1px) 0 0 / 100% 2rem,
        color-mix(in oklch, var(--bg-surface) 84%, transparent);
}

.note-card::after {
    position: absolute;
    top: -1px;
    right: -1px;
    width: 2.5rem;
    height: 2.5rem;
    border-bottom: var(--rule);
    border-left: var(--rule);
    background: color-mix(in oklch, var(--bg-main) 80%, var(--annotation) 8%);
    content: "";
    clip-path: polygon(100% 0, 100% 100%, 0 0);
}

.note-card:hover .note-copy h2 {
    color: var(--annotation);
}

.note-card:hover .note-image {
    border-color: var(--annotation);
}

.note-index {
    width: fit-content;
    padding: 0.14rem 0.36rem;
    border: 1px solid color-mix(in oklch, var(--border-color) 72%, transparent);
    border-radius: var(--radius-chip);
    color: var(--text-faint);
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 740;
}

.note-image {
    width: 100%;
    max-width: 140px;
    aspect-ratio: 14 / 11;
    border: var(--rule);
    border-radius: calc(var(--radius-card) - 0.12rem);
    object-fit: cover;
    filter: saturate(0.76) contrast(1.05);
}

.note-copy {
    display: grid;
    gap: 0.5rem;
}

.note-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--annotation);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-variation-settings: "MONO" 1, "CASL" 0;
    font-weight: 740;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

.note-copy h2 {
    max-width: 24ch;
    font-size: clamp(1.45rem, 3.2vw, 2.45rem);
    line-height: 1;
    transition: color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.note-copy p {
    max-width: 56rem;
    font-size: 1.02rem;
}

@media (min-width: 760px) {
    .note-card {
        grid-template-columns: 3rem minmax(0, 1fr) 132px;
    }
}

@media (max-width: 759px) {
    .note-card {
        grid-template-columns: 2.5rem minmax(0, 1fr);
        gap: 0.75rem;
    }

    .note-image {
        grid-column: 2;
        width: min(9rem, 44vw);
        max-width: none;
        margin-top: 0.25rem;
    }

    .note-copy {
        grid-column: 2;
    }

    .note-copy h2 {
        font-size: clamp(1.55rem, 8vw, 2.25rem);
    }

    .note-copy p {
        font-size: 0.98rem;
        line-height: 1.6;
    }
}
</style>
